{
  "entities": {
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Represents a high score entry by a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "score": { "type": "number" },
        "timestamp": { "type": "number" }
      },
      "required": ["uid", "displayName", "score", "timestamp"]
    }
  },
  "firestore": {
    "/leaderboard/{entryId}": {
      "schema": { "$ref": "#/entities/LeaderboardEntry" },
      "description": "Global leaderboard for BLOCK BURST 3."
    }
  }
}
