rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    
    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['uid', 'displayName', 'score', 'timestamp']) &&
             data.keys().size() == 4 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.timestamp is timestamp;
    }

    match /leaderboard/{entryId} {
      // Anyone can read the leaderboard
      allow read: if true;
      allow create: if isValidId(entryId) && incoming().uid == entryId && isValidLeaderboardEntry(incoming());
      allow update: if isValidId(entryId) && existing().uid == incoming().uid && isValidLeaderboardEntry(incoming()) && incoming().score >= existing().score;
      allow delete: if false;
    }
  }
}

